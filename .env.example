# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública do app (sem barra no final)
AUTH_URL=https://qualicontrol.tudomudou.com.br

# Gere com: openssl rand -base64 32
AUTH_SECRET=TROQUE_ISSO_POR_UMA_STRING_ALEATORIA_DE_32_BYTES

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://alchemy:SENHA_POSTGRES@postgres:5432/alchemy

POSTGRES_DB=alchemy
POSTGRES_USER=alchemy
POSTGRES_PASSWORD=TROQUE_AQUI

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:SENHA_REDIS@redis:6379
REDIS_PASSWORD=TROQUE_AQUI

# ─── MinIO (armazenamento de arquivos) ───────────────────────────────────────
MINIO_ROOT_USER=alchemy
MINIO_ROOT_PASSWORD=TROQUE_AQUI
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=alchemy-uploads

# ─── Resend (e-mail transacional) ─────────────────────────────────────────────
# Obtenha em resend.com — NUNCA commitar a chave real
RESEND_API_KEY=re_SUBSTITUA_SUA_CHAVE_AQUI
RESEND_FROM=noreply@tudomudou.com.br

# ─── Next.js ──────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
